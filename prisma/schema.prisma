model ReturnRequest {
  id                 Int       @id @default(autoincrement())
  orderId            Int
  order              Order     @relation("OriginalOrder", fields: [orderId], references: [id])
  customerId         Int?
  customer           Customer? @relation(fields: [customerId], references: [id])
  brand              String?
  type               String    // "return" | "exchange"
  reason             String
  status             String    @default("requested")
  requestedBy        String    @default("admin") // "customer" | "admin"
  adminNote          String?
  replacementOrderId Int?
  replacementOrder   Order?    @relation("ReplacementOrder", fields: [replacementOrderId], references: [id])
  stockReconciled    Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?

  @@index([orderId])
  @@index([brand, status, createdAt])
}
