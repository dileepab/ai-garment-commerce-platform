// This file was generated by Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  brand      String
  style      String
  price      Float
  fabric     String?
  sizes      String      // Store as JSON or comma-separated string
  colors     String      // Store as JSON or comma-separated string
  stock      Int         @default(0)
  status     String      @default("active")
  createdAt  DateTime    @default(now())
  inventory  Inventory?
  orderItems OrderItem[]
}

model Inventory {
  id                Int       @id @default(autoincrement())
  productId         Int       @unique
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  availableQty      Int       @default(0)
  reservedQty       Int       @default(0)
  inProductionQty   Int       @default(0)
  updatedAt         DateTime  @updatedAt
}

model Customer {
  id             Int       @id @default(autoincrement())
  externalId     String?   @unique // Meta sender ID or other integration ID
  name           String
  phone          String?
  channel        String?
  preferredBrand String?
  createdAt      DateTime  @default(now())
  orders         Order[]
  supportEscalations SupportEscalation[]
}

model Order {
  id              Int          @id @default(autoincrement())
  customerId      Int
  customer        Customer     @relation(fields: [customerId], references: [id])
  brand           String?
  orderStatus     String       @default("pending")
  totalAmount     Float
  paymentMethod   String?
  deliveryAddress String?
  giftWrap        Boolean      @default(false)
  giftNote        String?
  createdAt       DateTime     @default(now())
  orderItems      OrderItem[]
  supportEscalations SupportEscalation[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  size      String?
  color     String?
  quantity  Int
  price     Float
}

model ProductionBatch {
  id          Int       @id @default(autoincrement())
  brand       String?
  style       String?
  plannedQty  Int       @default(0)
  finishedQty Int       @default(0)
  rejectedQty Int       @default(0)
  status      String    @default("planned")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
}

model Operator {
  id               Int               @id @default(autoincrement())
  name             String
  skill            String?
  salaryBase       Float             @default(0)
  efficiency       Float             @default(0)
  status           String            @default("active")
  operatorOutputs  OperatorOutput[]
}

model OperatorOutput {
  id         Int      @id @default(autoincrement())
  operatorId Int
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  operation  String?
  outputQty  Int      @default(0)
  defects    Int      @default(0)
  efficiency Float    @default(0)
}

model Fabric {
  id         Int      @id @default(autoincrement())
  fabricType String
  color      String?
  meters     Float    @default(0)
  status     String   @default("available")
}

model Analytics {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now())
  sales      Float    @default(0)
  production Int      @default(0)
  profit     Float    @default(0)
  brand      String?
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  senderId  String   // Meta sender ID or phone number
  channel   String   @default("messenger") // messenger, instagram, whatsapp
  role      String   // "user" or "assistant"
  message   String
  createdAt DateTime @default(now())
}

model ConversationState {
  id        Int      @id @default(autoincrement())
  senderId  String
  channel   String   @default("messenger")
  stateJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, channel])
}

model SupportEscalation {
  id                  Int       @id @default(autoincrement())
  senderId            String
  channel             String    @default("messenger")
  customerId          Int?
  customer            Customer? @relation(fields: [customerId], references: [id])
  orderId             Int?
  order               Order?    @relation(fields: [orderId], references: [id])
  brand               String?
  reason              String
  status              String    @default("open")
  contactName         String?
  contactPhone        String?
  latestCustomerMessage String?
  summary             String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  resolvedAt          DateTime?

  @@index([senderId, channel, status])
}
